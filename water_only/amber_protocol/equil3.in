Equilibration 3: NPT, longer run with softer barostat coupling

&cntrl
  imin=0,           ! MD run (no minimization)
  ntx=5,            ! read coordinates and velocities from equil2.rst
  irest=1,          ! continue from previous simulation
  ntc=2, ntf=2,     ! SHAKE on bonds involving hydrogen
  nstlim=200000,    ! 200000 steps × 0.002 ps = 400 ps
  dt=0.002,         ! time step: 2 fs
  temp