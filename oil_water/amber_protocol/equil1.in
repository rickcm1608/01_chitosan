Equilibration 1: NVT with positional restraints on chitosan (CHI)

&cntrl
  imin=0,           ! MD run (no minimization)
  ntx=5,            ! read coordinates and velocities from heat.rst
  irest=1,          ! continue from previous simulation
  ntc=2, ntf=2,     ! SHAKE on bonds involving hydrogen
  nstlim=100000,    ! 100000 steps × 0.002 ps = 200 ps
  dt=0.002,         ! time step: 2 fs
  temp0=300,        ! target temperature: 300 K
  ntt=3,            ! Langevin thermostat
  gamma_ln=2.0,     ! collision frequency: 2 ps⁻¹
  ntb=1,            ! constant volume (NVT)
  ntpr=500, ntwx=500, ntwr=5000,  ! output frequencies
  ioutfm=1, ntxo=2, ! binary trajectory and restart formats
  ntr=1,            ! enable pos